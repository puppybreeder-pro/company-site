---
import '../styles/global.css';
import { Toaster } from '../ui/sonner';
import { faqData } from '../data/faqData';

const {
  title = 'PuppyBreeder.PRO — Professional Websites for Dog Breeders',
  description = 'Professional websites for dog breeders — launched in 48 hours, fully managed, purpose-built for your breeding program.',
  ogImage = new URL('/images/og-default.jpg', 'https://www.puppybreeder.pro').href,
  includeFaqSchema = true,
  includeOfferSchema = true,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://www.puppybreeder.pro');

const siteName = 'PuppyBreeder.PRO';

const faqSchema = includeFaqSchema ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
} : null;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'PuppyBreeder.PRO',
  description: description,
  url: 'https://www.puppybreeder.pro',
  logo: 'https://www.puppybreeder.pro/favicon.svg',
  priceRange: '$$',
  telephone: '+1-555-000-0000',
  email: 'steven@puppybreeder.pro',
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'US',
  },
  sameAs: [],
};

const defaultOfferSchema = includeOfferSchema ? {
  '@context': 'https://schema.org',
  '@type': 'Offer',
  name: 'Gold Standard Plan',
  description: 'Fully hosted, branded website for dog breeders with custom design, admin dashboard, puppy listings, and managed hosting.',
  url: 'https://www.puppybreeder.pro/offer#pricing',
  priceCurrency: 'USD',
  price: '99.00',
  priceValidUntil: '2027-12-31',
  availability: 'https://schema.org/InStock',
  offeredBy: {
    '@type': 'LocalBusiness',
    name: 'PuppyBreeder.PRO',
  },
} : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#5e3ae3" />

    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Instrument+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={siteName} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    {defaultOfferSchema && <script type="application/ld+json" set:html={JSON.stringify(defaultOfferSchema)} />}

    <title>{title}</title>
  </head>
  <body class="bg-background text-foreground" data-no-transitions>
    <slot />
    <Toaster client:load theme="light" />

    <script>
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          document.body.removeAttribute('data-no-transitions');
        });
      });

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!prefersReduced) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.setAttribute('data-revealed', '');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -60px 0px' }
        );
        document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
      } else {
        document.querySelectorAll('[data-reveal]').forEach((el) => {
          el.setAttribute('data-revealed', '');
        });
      }
    </script>
  </body>
</html>