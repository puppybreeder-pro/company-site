---
import Layout from '../layouts/Layout.astro';
import { Header } from '../components/Header.jsx';
import { Hero } from '../components/Hero.jsx';
import ProblemSolution from '../components/ProblemSolution.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Features from '../components/Features.astro';
import { LeadMagnet } from '../components/LeadMagnet.jsx';
import { Pricing } from '../components/Pricing.jsx';
import Testimonials from '../components/Testimonials.astro';
import Showroom from '../components/Showroom.astro';
import FounderSection from '../components/FounderSection.astro';
import { FAQ } from '../components/FAQ.jsx';
import { EthicalCommitment } from '../components/EthicalCommitment.jsx';
import { CTA } from '../components/CTA.jsx';
import Footer from '../components/Footer.astro';
import { faqData } from '../data/faqData';

const offerTitle = 'PuppyBreeder.PRO — Explore Our Platform';
const offerDescription = 'Professional websites for dog breeders — launched in 72 hours, fully managed, purpose-built for your breeding program.';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const offerSchema = {
  '@context': 'https://schema.org',
  '@type': 'Offer',
  name: 'Gold Standard Plan',
  description: 'Fully hosted, branded website for dog breeders with custom design, admin dashboard, puppy listings, and managed hosting.',
  url: 'https://www.puppybreeder.pro/offer#pricing',
  priceCurrency: 'USD',
  price: '99.00',
  priceValidUntil: '2027-12-31',
  availability: 'https://schema.org/InStock',
  offeredBy: {
    '@type': 'LocalBusiness',
    name: 'PuppyBreeder.PRO',
  },
};
---

<Layout
  title={offerTitle}
  description={offerDescription}
  includeFaqSchema={false}
  includeOfferSchema={false}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(offerSchema)} />

  <Header client:load />
  <main>
    <Hero client:load />
    <div data-reveal>
      <ProblemSolution />
    </div>
    <div data-reveal>
      <HowItWorks />
    </div>
    <div data-reveal>
      <Features />
    </div>
    <div data-reveal>
      <LeadMagnet client:visible />
    </div>
    <div data-reveal>
      <Pricing client:load />
    </div>
    <div data-reveal>
      <Testimonials />
    </div>
    <div data-reveal>
      <Showroom />
    </div>
    <div data-reveal>
      <FounderSection />
    </div>
    <div data-reveal>
      <FAQ client:visible />
    </div>
    <div data-reveal>
      <EthicalCommitment client:visible />
    </div>
    <div data-reveal>
      <CTA client:visible />
    </div>
  </main>
  <Footer />
</Layout>