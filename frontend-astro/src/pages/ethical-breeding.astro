---
import Layout from '../layouts/Layout.astro';
import EthicsHeader from '../components/ethical-breeding/EthicsHeader.astro';
import EthicsHero from '../components/ethical-breeding/EthicsHero.astro';
import EthicsCrisis from '../components/ethical-breeding/EthicsCrisis.astro';
import EthicsCommitment from '../components/ethical-breeding/EthicsCommitment.astro';
import EthicsReportCTA from '../components/ethical-breeding/EthicsReportCTA.astro';
import Footer from '../components/Footer.astro';

const ethicsTitle = 'Our Ethical Breeding Commitment — PuppyBreeder.PRO';
const ethicsDescription = 'PuppyBreeder.PRO exclusively serves licensed, professional breeders who prioritize animal welfare and ethical breeding practices. Learn about our verification process and code of conduct.';
---

<Layout
  title={ethicsTitle}
  description={ethicsDescription}
  includeFaqSchema={false}
  includeOfferSchema={false}
>
  <EthicsHeader />
  <main>
    <EthicsHero />
    <div data-reveal>
      <EthicsCrisis />
    </div>
    <div data-reveal>
      <EthicsCommitment />
    </div>
    <div data-reveal>
      <EthicsReportCTA />
    </div>
  </main>
  <Footer />
</Layout>