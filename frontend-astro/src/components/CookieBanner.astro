---
const STORAGE_KEY = 'pbp_cookie_banner_dismissed';
---

<script is:inline>
  try {
    const raw = localStorage.getItem('pbp_cookie_banner_dismissed');
    const dismissed =
      raw === '1' || (typeof raw === 'string' && raw.length > 0 && !Number.isNaN(Date.parse(raw)));
    if (dismissed) {
      document.documentElement.setAttribute('data-pbp-cookie-dismissed', '');
    }
  } catch {}
</script>

<style is:global>
  html[data-pbp-cookie-dismissed] #pbp-cookie-banner {
    display: none !important;
  }
</style>

<div
  id="pbp-cookie-banner"
  class="pointer-events-none fixed bottom-0 left-0 right-0 z-50 flex justify-center p-4 pb-[max(1rem,env(safe-area-inset-bottom))]"
  role="region"
  aria-label="Cookie notice"
>
  <div
    class="pointer-events-auto glass w-full max-w-md rounded-xl border border-border shadow-xl sm:max-w-lg"
  >
    <div class="flex flex-col gap-3 p-4 sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:p-4">
      <p class="text-sm leading-relaxed text-foreground">
        We use cookies to understand traffic and improve the site. See our{' '}
        <a
          href="/privacy/"
          class="font-medium text-primary underline-offset-2 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
        >
          privacy policy
        </a>
        .
      </p>
      <button
        type="button"
        id="pbp-cookie-banner-accept"
        class="shrink-0 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
      >
        Got it
      </button>
    </div>
  </div>
</div>

<script define:vars={{ STORAGE_KEY }}>
  document.getElementById('pbp-cookie-banner-accept')?.addEventListener('click', () => {
    try {
      localStorage.setItem(STORAGE_KEY, new Date().toISOString());
    } catch {}
    document.documentElement.setAttribute('data-pbp-cookie-dismissed', '');
  });
</script>
