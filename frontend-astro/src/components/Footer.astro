---
import { Icon } from "astro-icon/components";
import { footerLinks, breeds, socialLinks } from "../data/footerData";
import { BRAND_NAME, BRAND_SUFFIX } from "../constants";
---

<footer class="bg-primary/5 border-t border-border">
  <div class="container-custom py-12">
    <div class="grid md:grid-cols-4 gap-8 mb-8">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-10 h-10 flex items-center justify-center">
            <span class="text-2xl">🐾</span>
          </div>
          <span class="text-xl font-bold text-foreground">
            {BRAND_NAME}<span class="text-primary">{BRAND_SUFFIX}</span>
          </span>
        </div>
        <p class="text-sm text-muted-foreground mb-4 max-w-md">
          The website platform built for dog breeders—and only dog breeders.
          Professional sites you can actually manage.
        </p>
        <p class="text-xs text-muted-foreground">
          Supporting 28+ breeds including:
        </p>
        <div class="flex flex-wrap gap-2 mt-2">
          {
            breeds
              .slice(0, 4)
              .map((breed, index) => (
                <span class="text-xs bg-accent/10 text-accent px-2 py-1 rounded">
                  {breed}
                </span>
              ))
          }
          <span
            class="text-xs bg-accent/10 text-accent px-2 py-1 rounded font-medium"
          >
            +24 more
          </span>
        </div>
      </div>

      <div>
        <h4 class="font-semibold text-foreground mb-4">Product</h4>
        <ul class="space-y-2">
          {
            footerLinks.product.map((link, index) => (
              <li>
                <a
                  href={`#${link.id}`}
                  class="text-sm text-muted-foreground hover:text-primary transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-foreground mb-4">Support</h4>
        <ul class="space-y-2">
          {
            footerLinks.support.map((link, index) => (
              <li>
                {link.id ? (
                  <a
                    href={`#${link.id}`}
                    class="text-sm text-muted-foreground hover:text-primary transition-colors"
                  >
                    {link.label}
                  </a>
                ) : (
                  <a
                    href={link.href}
                    class="text-sm text-muted-foreground hover:text-primary transition-colors"
                  >
                    {link.label}
                  </a>
                )}
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="flex justify-center items-center my-4">
      <a
        href="https://www.puppybreeder.pro/"
        aria-label="Visit PuppyBreeder.PRO"
      >
        <img
          src="https://api.puppybreedr.pro/badge"
          alt="PBP Badge"
          class="h-auto max-w-full"
        />
      </a>
    </div>

    <div class="pt-8 border-t border-border">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-sm text-muted-foreground">
          &copy; {new Date().getFullYear()} PuppyBreeder.PRO. All rights reserved.
        </p>
        <div class="flex items-center gap-5">
          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <span>Made with</span>
            <Icon name="lucide:heart" class="w-4 h-4 text-accent fill-accent" />
            <span>for dog breeders</span>
          </div>
          <div class="flex items-center gap-3">
            {
              socialLinks.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Visit ${link.label}`}
                  class="text-muted-foreground hover:text-primary transition-colors"
                >
                  <Icon name={link.icon} class="w-5 h-5" />
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
