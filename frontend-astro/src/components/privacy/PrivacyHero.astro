---
import { Icon } from 'astro-icon/components';
import { PRIVACY_EMAIL } from '../../constants/index.js';
---

<section class="pt-20 pb-10 md:pt-28 md:pb-14 bg-linear-to-b from-primary/5 to-background border-b border-border/60">
  <div class="container-custom">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-full mb-6">
        <Icon name="lucide:shield-check" class="w-8 h-8 text-primary" aria-hidden="true" />
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-foreground mb-5 leading-tight">
        Privacy Policy
      </h1>
      <p class="text-lg text-muted-foreground leading-relaxed max-w-2xl mx-auto">
        How PuppyBreeder.PRO collects, uses, and discloses personal information when you use our website and
        services.
      </p>
      <p class="mt-5 text-sm text-muted-foreground max-w-2xl mx-auto">
        Privacy questions or requests:{' '}
        <a
          href={`mailto:${PRIVACY_EMAIL}`}
          class="text-primary font-medium underline underline-offset-2 hover:text-primary/80"
        >
          {PRIVACY_EMAIL}
        </a>
      </p>
      <p class="mt-6 text-sm text-muted-foreground">
        <span class="font-medium text-foreground">Last updated:</span> May 11, 2026
      </p>
    </div>
  </div>
</section>
