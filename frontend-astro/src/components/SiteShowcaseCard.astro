---
const { site } = Astro.props;
---

<a
  href={`https://${site.url}`}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`Open ${site.kennel} website in a new tab`}
  data-testid={`site-showcase-${site.url}`}
  class="block focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded-lg"
>
  <div class="overflow-hidden group hover-lift bg-card cursor-pointer rounded-xl border shadow">
    <div class="flex items-center gap-2 px-3 py-2 bg-muted border-b border-border">
      <span class="w-2.5 h-2.5 rounded-full bg-salmon" />
      <span class="w-2.5 h-2.5 rounded-full bg-mediumpurple" />
      <span class="w-2.5 h-2.5 rounded-full bg-darkseagreen" />
      <span class="ml-3 text-[10px] text-muted-foreground font-mono truncate">
        {site.url}
      </span>
    </div>

    <img
      src={site.image}
      alt={`${site.kennel} website preview`}
      class="w-full aspect-[16/10] object-cover transition-transform duration-500 group-hover:scale-[1.02]"
    />

    <div class="p-5 border-t border-border">
      <h4 class="font-bold text-lg text-foreground mb-1 group-hover:text-primary transition-colors">
        {site.kennel}
      </h4>
      <p class="text-sm text-muted-foreground">
        {site.breed} <span class="text-foreground/40 mx-1">·</span> {site.location}
      </p>
    </div>
  </div>
</a>