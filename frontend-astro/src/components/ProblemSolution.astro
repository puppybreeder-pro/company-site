---
import { Icon } from "astro-icon/components";
import { problems, solutions } from "../data/problemSolutionData";
---

<section class="section-padding bg-muted/30">
  <div class="container-custom">
    <div class="text-center mb-12">
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground mb-4"
      >
        We Get It. Website Builders Weren't Made for Breeders.
      </h2>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        You're a professional breeder, not a web developer. Your time should be
        spent with your dogs, not debugging drag-and-drop layouts.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 max-w-6xl mx-auto">
      <div class="p-8 bg-card border-2 border-destructive/20 rounded-xl shadow">
        <div
          class="flex items-center justify-center lg:justify-start gap-3 mb-6"
        >
          <div
            class="w-12 h-12 rounded-full bg-destructive/10 flex items-center justify-center flex-shrink-0"
          >
            <Icon name="lucide:x" class="w-6 h-6 text-destructive" />
          </div>
          <h3 class="text-2xl font-bold text-foreground">The Old Way</h3>
        </div>
        <div class="flex justify-center lg:justify-start">
          <ul class="space-y-4 text-left">
            {
              problems.map((problem) => (
                <li class="flex gap-3">
                  <Icon
                    name="lucide:x"
                    class="w-5 h-5 text-destructive flex-shrink-0 mt-0.5"
                  />
                  <span class="text-foreground/80">{problem}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="p-8 bg-card border-2 border-success rounded-xl shadow">
        <div
          class="flex items-center justify-center lg:justify-start gap-3 mb-6"
        >
          <div
            class="w-12 h-12 rounded-full bg-success/10 flex items-center justify-center flex-shrink-0"
          >
            <Icon name="lucide:check" class="w-6 h-6 text-success" />
          </div>
          <h3 class="text-2xl font-bold text-foreground">
            The PuppyBreeder.PRO Way
          </h3>
        </div>
        <div class="flex justify-center lg:justify-start">
          <ul class="space-y-4 text-left">
            {
              solutions.map((solution) => (
                <li class="flex gap-3">
                  <Icon
                    name="lucide:check"
                    class="w-5 h-5 text-success flex-shrink-0 mt-0.5"
                  />
                  <span class="text-foreground/80">{solution}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <p
      class="text-sm sm:text-base italic text-muted-foreground max-w-4xl mx-auto text-center mt-10 leading-relaxed"
    >
      PuppyBreeder.PRO is made for serious, ethical, non-technical dog breeders
      who want a professional online presence without doing the tech
      themselves&mdash;so the right families find you easier, trust you faster,
      inquire confidently, and your puppies are placed in better homes.
    </p>
  </div>
</section>
