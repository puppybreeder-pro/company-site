---
import SiteShowcaseCard from './SiteShowcaseCard.astro';
import { showroomSites } from '../data/showroomData';
---

<section
  id="showroom"
  class="section-padding bg-background"
  data-testid="live-sites-showcase"
>
  <div class="container-custom">
    <div class="text-center mb-10 max-w-2xl mx-auto">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground mb-3">
        Showroom
      </h2>
      <p class="text-base text-muted-foreground leading-relaxed">
        Recent websites built on PuppyBreeder.PRO — each custom-designed to reflect the breed, the kennel, and the families they serve.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6 max-w-5xl mx-auto">
      {showroomSites.map((site) => (
        <SiteShowcaseCard site={site} />
      ))}
    </div>
  </div>
</section>