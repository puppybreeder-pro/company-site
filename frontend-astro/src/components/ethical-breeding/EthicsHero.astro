---
import { Icon } from 'astro-icon/components';
---

<section class="pt-20 pb-12 md:pt-28 md:pb-16 bg-gradient-to-b from-primary/5 to-background">
  <div class="container-custom">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-full mb-6">
        <Icon name="lucide:shield-check" class="w-8 h-8 text-primary" />
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-foreground mb-6 leading-tight">
        Our Ethical Commitment
      </h1>
      <p class="text-lg sm:text-xl text-muted-foreground leading-relaxed max-w-2xl mx-auto">
        PuppyBreeder.PRO exclusively serves licensed, professional breeders who
        prioritize animal welfare and ethical breeding practices.
      </p>
    </div>
  </div>
</section>