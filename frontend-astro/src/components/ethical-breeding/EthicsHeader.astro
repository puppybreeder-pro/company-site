---
import { BRAND_NAME, BRAND_SUFFIX } from '../../constants/index.js';
---

<header class="sticky top-0 z-50 w-full border-b border-border/40 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="container-custom flex h-16 items-center justify-between">
    <a href="/" class="flex items-center text-xl font-bold text-foreground hover:text-primary transition-colors cursor-pointer">
      {BRAND_NAME}<span class="text-primary">{BRAND_SUFFIX}</span>
    </a>
    <a
      href="/report"
      class="inline-flex items-center justify-center h-10 rounded-lg px-6 text-sm font-medium bg-accent text-accent-foreground shadow hover:bg-accent/90 hover:shadow-lg transition-all cursor-pointer"
    >
      Report a Breeder
    </a>
  </div>
</header>