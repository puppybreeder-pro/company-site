---
import { BRAND_NAME, BRAND_SUFFIX } from '../../constants/index.js';
---

<header class="sticky top-0 z-50 w-full border-b border-border/40 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="container-custom flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex shrink-0 items-center text-xl font-bold text-foreground hover:text-primary transition-colors cursor-pointer">
      {BRAND_NAME}<span class="text-primary">{BRAND_SUFFIX}</span>
    </a>
    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href="/ethical-breeding"
        class="hidden text-sm font-medium text-muted-foreground hover:text-primary transition-colors shrink-0 sm:inline"
      >
        Ethics
      </a>
      <a
        href="/"
        class="inline-flex items-center justify-center h-10 shrink-0 rounded-lg px-5 text-sm font-medium border border-input bg-background hover:bg-accent hover:text-accent-foreground shadow-sm transition-all cursor-pointer"
      >
        Back to Home
      </a>
    </div>
  </div>
</header>
